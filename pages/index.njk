---
layout: base.njk
title: Karl Mayer
pagination:
  data: collections.posts
  size: 10
  reverse: true

---

<span id="icon-bar">
  <div class="rss-wrap">
    <button id="rss-btn" aria-label="Subscribe via RSS" aria-expanded="false">
      <img src="/img/feed_icon.svg" alt="RSS/Atom Feed">
    </button>
    <div id="rss-popover" hidden>
      <p>Paste this URL into your feed reader:</p>
      <div class="rss-url-row">
        <code>https://www.karlmayer.dev/feed.xml</code>
        <button id="rss-copy">Copy</button>
      </div>
    </div>
  </div>
</span>
{% for post in pagination.items %}
  <article class="blog-post" data-post-url="{{ post.url | url }}">
    <time datetime="{{ post.date | dateIso }}">{{
      post.date | dateInternational
    }}</time><br>
    <h1>
      <a href="{{ post.url | url }}">{{ post.data.title }}</a>
    </h1>
    <section>
      <div class="excerpt">{% excerpt post %}</div>
      <button
        aria-label="Read more on {{ post.data.title }}"
        aria-expanded="false"
        class="read_more"
      >Read more...</button>
    </section>
    <hr>
  </article>
{% endfor %}

<script>
(function () {
  var articles = document.querySelectorAll('article.blog-post[data-post-url]');
  if (!articles.length) return;

  history.replaceState({ home: true }, '', location.href);

  function applyBlockquoteCopy(root) {
    var iconCopy = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
    var iconCheck = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
    root.querySelectorAll('blockquote').forEach(function (bq) {
      var btn = document.createElement('button');
      btn.className = 'blockquote-copy';
      btn.setAttribute('aria-label', 'Copy quote');
      btn.innerHTML = iconCopy;
      function doCopy() {
        var text = bq.innerText.replace(/\n+/g, ' ').trim();
        navigator.clipboard.writeText(text).then(function () {
          btn.innerHTML = iconCheck;
          setTimeout(function () { btn.innerHTML = iconCopy; }, 1500);
        });
      }
      btn.addEventListener('click', function (e) { e.stopPropagation(); doCopy(); });
      bq.addEventListener('click', doCopy);
      bq.style.cursor = 'pointer';
      bq.appendChild(btn);
    });
  }

  function applyExternalLinks(root) {
    root.querySelectorAll('a').forEach(function (a) {
      var href = a.href.toLowerCase();
      if (!(href.includes('://localhost') || href.includes('karlmayer.dev') || href.includes('karlmayer.github.io'))) {
        a.setAttribute('target', '_blank');
      }
    });
  }

  function collapseArticle(article) {
    var full = article.querySelector('.post-full');
    var excerpt = article.querySelector('.excerpt');
    var btn = article.querySelector('.read_more');
    if (full) full.remove();
    if (excerpt) excerpt.hidden = false;
    if (btn) {
      btn.hidden = false;
      btn.disabled = false;
      btn.textContent = 'Read more...';
      btn.setAttribute('aria-expanded', 'false');
    }
  }

  async function expandArticle(article) {
    var postUrl = article.dataset.postUrl;
    var excerpt = article.querySelector('.excerpt');
    var btn = article.querySelector('.read_more');
    btn.textContent = 'Loading...';
    btn.disabled = true;
    try {
      var res = await fetch(postUrl);
      var html = await res.text();
      var doc = new DOMParser().parseFromString(html, 'text/html');
      var section = doc.querySelector('.blog-post section');
      if (section) {
        var full = document.createElement('div');
        full.className = 'post-full';
        full.innerHTML = section.innerHTML;
        applyExternalLinks(full);
        applyBlockquoteCopy(full);
        full.style.overflow = 'hidden';
        full.style.maxHeight = '0';
        excerpt.after(full);
        full.querySelectorAll('script').forEach(function (oldScript) {
          var newScript = document.createElement('script');
          Array.from(oldScript.attributes).forEach(function (attr) {
            newScript.setAttribute(attr.name, attr.value);
          });
          newScript.textContent = oldScript.textContent;
          oldScript.replaceWith(newScript);
        });
        excerpt.hidden = true;
        btn.hidden = true;
        btn.setAttribute('aria-expanded', 'true');
        requestAnimationFrame(function () {
          full.style.transition = 'max-height 0.9s ease';
          full.style.maxHeight = full.scrollHeight + 'px';
          full.addEventListener('transitionend', function () {
            full.style.maxHeight = '';
            full.style.overflow = '';
            full.style.transition = '';
          }, { once: true });
        });
      }
    } catch (e) {
      btn.textContent = 'Read more...';
      btn.disabled = false;
    }
  }

  articles.forEach(function (article) {
    var btn = article.querySelector('.read_more');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var postUrl = article.dataset.postUrl;
      expandArticle(article);
      history.pushState({ postUrl: postUrl }, '', postUrl);
    });
  });

  window.addEventListener('popstate', function (e) {
    if (!e.state || e.state.home) {
      articles.forEach(collapseArticle);
    } else if (e.state.postUrl) {
      articles.forEach(collapseArticle);
      var article = document.querySelector('article[data-post-url="' + e.state.postUrl + '"]');
      if (article) expandArticle(article);
    }
  });
})();

(function () {
  var btn = document.getElementById('rss-btn');
  var popover = document.getElementById('rss-popover');
  var copy = document.getElementById('rss-copy');

  btn.addEventListener('click', function (e) {
    e.stopPropagation();
    var open = !popover.hidden;
    popover.hidden = open;
    btn.setAttribute('aria-expanded', String(!open));
  });

  copy.addEventListener('click', function () {
    navigator.clipboard.writeText('https://www.karlmayer.dev/feed.xml').then(function () {
      copy.textContent = 'Copied!';
      setTimeout(function () { copy.textContent = 'Copy'; }, 2000);
    });
  });

  document.addEventListener('click', function (e) {
    if (!popover.hidden && !popover.contains(e.target)) {
      popover.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !popover.hidden) {
      popover.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
      btn.focus();
    }
  });
})();
</script>
