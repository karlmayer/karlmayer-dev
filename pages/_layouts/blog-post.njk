---
layout: base.njk
ogType: "article"
permalink: "post/{{ page.date | datePath }}/{{ title | slugify }}/index.html"
---

<div class="post-back">
  <a href="/" class="nav-link">← All posts</a>
</div>
<article class="blog-post">
  <time datetime="{{ page.date | dateIso }}">{{ page.date | dateInternational }}</time>
  <h1>{{title}}</h1>
  <section>
    {{ content | safe }}
  </section>
  {% if postNav and (postNav.newer or postNav.older) %}
    <nav class="post-nav" aria-label="Post navigation">
      {% if postNav.newer %}
        <a href="{{ postNav.newer.url | url }}" class="nav-link post-nav-link post-nav-link-prev" aria-label="Read newer post: {{ postNav.newer.data.title }}">
          <span>← Newer</span>
          <strong>{{ postNav.newer.data.title }}</strong>
        </a>
      {% else %}
        <span class="post-nav-spacer" aria-hidden="true"></span>
      {% endif %}

      {% if postNav.older %}
        <a href="{{ postNav.older.url | url }}" class="nav-link post-nav-link post-nav-link-next" aria-label="Read older post: {{ postNav.older.data.title }}">
          <span>Older →</span>
          <strong>{{ postNav.older.data.title }}</strong>
        </a>
      {% else %}
        <span class="post-nav-spacer" aria-hidden="true"></span>
      {% endif %}
    </nav>
  {% endif %}
</article>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "datePublished": "{{ page.date | dateInternational }}",
  "author": {
    "@type": "Person",
    "name": "Karl Mayer",
    "url": "https://www.karlmayer.dev/resume/"
  },
  "publisher": {
    "@type": "Person",
    "name": "Karl Mayer"
  },
  "url": "https://www.karlmayer.dev{{ page.url }}"
}
</script>
